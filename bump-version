#!/bin/bash

# --- Parse Command Line Arguments ---
BUMP_TYPE="minor" # Default to minor
SKIP_SWITCH=false # Default to switching to develop branch

while [[ $# -gt 0 ]]; do
    case $1 in
        --patch)
            BUMP_TYPE="patch"
            shift
            ;;
        --minor)
            BUMP_TYPE="minor"
            shift
            ;;
        --major)
            BUMP_TYPE="major"
            shift
            ;;
        --no-switch|--current)
            SKIP_SWITCH=true
            shift
            ;;
        -h|--help)
            echo "Usage: $0 [--patch|--minor|--major] [--no-switch]"
            echo ""
            echo "Options:"
            echo "  --patch      Bump patch version (X.Y.Z -> X.Y.Z+1)"
            echo "  --minor      Bump minor version (X.Y.Z -> X.Y+1.0) [default]"
            echo "  --major      Bump major version (X.Y.Z -> X+1.0.0)"
            echo "  --no-switch  Stay on current branch (skip switching to develop)"
            echo "  --current    Alias for --no-switch"
            echo "  -h, --help   Show this help message"
            exit 0
            ;;
        *)
            echo "🚨 Error: Unknown option '$1'"
            echo "Use --help for usage information."
            exit 1
            ;;
    esac
done

# --- Configuration ---
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)

# Skip branch switching if --no-switch flag is set
if [ "$SKIP_SWITCH" = true ]; then
    echo "ℹ️  Staying on current branch **$CURRENT_BRANCH** (--no-switch)."
    DEVELOP_BRANCH=""
else
    # Detect develop branch (check for 'develop' or 'dev')
    if git show-ref --verify --quiet refs/heads/develop; then
        DEVELOP_BRANCH="develop"
    elif git show-ref --verify --quiet refs/heads/dev; then
        DEVELOP_BRANCH="dev"
    else
        DEVELOP_BRANCH=""
    fi

    # Switch to develop branch if it exists
    if [ -n "$DEVELOP_BRANCH" ]; then
        git checkout $DEVELOP_BRANCH
        echo "✅ Switched to branch **$DEVELOP_BRANCH**."
        CURRENT_BRANCH="$DEVELOP_BRANCH"
    else
        echo "ℹ️  No develop branch found. Staying on current branch **$CURRENT_BRANCH**."
    fi
fi

# --- File Detection Logic ---
VERSION_FILE=""
if [ -f "app.yml" ]; then
    VERSION_FILE="app.yml"
elif [ -f "package.yml" ]; then
    VERSION_FILE="package.yml"
elif [ -f "package.json" ]; then
    VERSION_FILE="package.json"
else
    echo "🚨 Error: Could not find a supported version file (app.yml, package.yml, or package.json) in the current directory."
    echo "Please ensure one of these files exists."
    exit 1
fi

# Capitalize bump type for display
BUMP_TYPE_DISPLAY=$(echo "$BUMP_TYPE" | awk '{print toupper(substr($0,1,1)) tolower(substr($0,2))}')

echo "--- Starting $BUMP_TYPE_DISPLAY Version Bump ---"
echo "Detected Version File: **$VERSION_FILE**"


# 1. Get current version (Supports YAML and JSON formats)
# This grep attempts to find the version string, common patterns:
# 'version: X.Y.Z' (YAML) or '"version": "X.Y.Z"' (JSON)
CURRENT_VERSION=$(grep -oE 'version["'']?[[:space:]]*:?[[:space:]]*["'']?[0-9]+\.[0-9]+\.[0-9]+' "$VERSION_FILE" | grep -oE '[0-9]+\.[0-9]+\.[0-9]+$' | head -n 1)

if [ -z "$CURRENT_VERSION" ]; then
    echo "🚨 Error: Could not find a version string (X.Y.Z format) in $VERSION_FILE."
    echo "Check if the format 'X.Y.Z' is present after 'version:' or '\"version\":'."
    exit 1
fi

echo "Current project version: **$CURRENT_VERSION**"

# 2. Extract and calculate the new version based on bump type
IFS='.' read -r MAJOR MINOR PATCH <<< "$CURRENT_VERSION"

case $BUMP_TYPE in
    patch)
        NEW_PATCH=$((PATCH + 1))
        NEW_VERSION="$MAJOR.$MINOR.$NEW_PATCH"
        ;;
    minor)
        NEW_MINOR=$((MINOR + 1))
        NEW_VERSION="$MAJOR.$NEW_MINOR.0"
        ;;
    major)
        NEW_MAJOR=$((MAJOR + 1))
        NEW_VERSION="$NEW_MAJOR.0.0"
        ;;
esac

echo "New Release Version will be: **$NEW_VERSION**"

# 6. Update only the first version occurrence in the file
tmp_file="${VERSION_FILE}.tmp.$$"
awk -v new_version="$NEW_VERSION" '
BEGIN { replaced = 0 }
{
    if (!replaced && tolower($0) ~ /version/ && match($0, /[0-9]+\.[0-9]+\.[0-9]+/)) {
        $0 = substr($0, 1, RSTART - 1) new_version substr($0, RSTART + RLENGTH)
        replaced = 1
    }
    print
}
' "$VERSION_FILE" > "$tmp_file" && mv "$tmp_file" "$VERSION_FILE"

echo "✅ Updated $VERSION_FILE to **$NEW_VERSION**."

# 7. Commit the version change
git add "$VERSION_FILE"
git commit -m "chore: Bump $VERSION_FILE to $NEW_VERSION"
echo "✅ Committed version bump."

echo "--- **SUCCESS** ---"
if [ -n "$DEVELOP_BRANCH" ]; then
    echo "Version bumped to **$NEW_VERSION** (develop branch: $DEVELOP_BRANCH)"
else
    echo "Version bumped to **$NEW_VERSION** on current branch **$CURRENT_BRANCH**."
fi
